{
  "name": "trackt",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, self-hostable tracker for movies, series, anime, manga, and webtoons.",
  "license": "GPL-3.0-only",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @trackt/db db:generate",
    "db:migrate": "pnpm --filter @trackt/db db:migrate"
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "turbo": "^2.10.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
