{
  "name": "trackt",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, self-hostable tracker for movies, series, anime, manga, and webtoons.",
  "license": "GPL-3.0-only",
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "eslint .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "pnpm --filter @trackt/db db:generate",
    "db:migrate": "pnpm --filter @trackt/db db:migrate",
    "db:seed": "pnpm --filter @trackt/db db:seed",
    "db:set-role": "pnpm --filter @trackt/db db:set-role"
  },
  "devDependencies": {
    "eslint": "^10.6.0",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.10.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
