# Trackt configuration
# All configuration is done via environment variables, validated at startup.
# In development every variable has a sensible default — you can run with no .env at all.
# In production (NODE_ENV=production) the variables marked [required] must be set.

NODE_ENV=development

# ── Server ────────────────────────────────────────────────────────────────────
# Port the API listens on (the web dev server runs on 3000 and proxies /api here)
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Public URL of the instance (used for auth callbacks, absolute links)
APP_URL=http://localhost:3000

# ── Database & cache ─────────────────────────────────────────────────────────
# [required in production]
DATABASE_URL=postgres://trackt:trackt@localhost:5432/trackt
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
# [required in production] Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Catalog (ADR-0001) ───────────────────────────────────────────────────────
# Base URL of the central slim catalog the worker syncs media from.
# Development defaults to the local catalog service (apps/catalog, port 3002).
# Leaving it unset in production disables catalog sync (search stays empty).
CATALOG_URL=

# Optional, reserved for future per-instance enrichment (descriptions/posters).
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── Storage (covers for user-created entries) ────────────────────────────────
# Local directory by default; set the S3_* variables to use S3-compatible storage.
UPLOADS_DIR=./data/uploads
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=

# Only used with the optional bundled MinIO (docker compose --profile minio).
# [required for that profile] MinIO refuses to start without a root password.
# MINIO_ROOT_USER=trackt
# MINIO_ROOT_PASSWORD=
