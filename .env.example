# Trackt configuration
# All configuration is done via environment variables, validated at startup.
# In development every variable has a sensible default — you can run with no .env at all.
# In production (NODE_ENV=production) the variables marked [required] must be set.

NODE_ENV=development

# ── Server ────────────────────────────────────────────────────────────────────
# Port the API listens on (the web dev server runs on 3000 and proxies /api here)
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Public URL of the instance (used for auth callbacks, absolute links)
APP_URL=http://localhost:3000

# ── Database & cache ─────────────────────────────────────────────────────────
# [required in production]
DATABASE_URL=postgres://trackt:trackt@localhost:5432/trackt
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────────────────────────────
# [required in production] Generate with: openssl rand -base64 32
AUTH_SECRET=

# ── Metadata providers ───────────────────────────────────────────────────────
# Optional but strongly recommended: movie/series metadata comes from TMDB.
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# ── Storage (covers for user-created entries) ────────────────────────────────
# Local directory by default; set the S3_* variables to use S3-compatible storage.
UPLOADS_DIR=./data/uploads
# S3_ENDPOINT=
# S3_REGION=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
