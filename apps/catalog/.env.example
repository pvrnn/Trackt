# Trackt catalog service configuration (apps/catalog, ADR-0001).
# The central slim catalog — a separate, project-operated service, NOT part
# of the self-hosted docker-compose.yml. All configuration is via
# environment variables, validated at startup (packages/shared/src/env-catalog.ts).
# In development every variable has a sensible default — you can run with no .env at all.
# In production (NODE_ENV=production) the variables marked [required] must be set.

NODE_ENV=development

# ── Server ────────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=3002
LOG_LEVEL=info

# ── Database ──────────────────────────────────────────────────────────────────
# [required in production] Dedicated catalog Postgres — NOT the monolith's DB.
# Migrations run automatically on boot (apps/catalog/src/db/index.ts).
DATABASE_URL=postgres://trackt:trackt@localhost:5433/trackt_catalog

# ── Admin ─────────────────────────────────────────────────────────────────────
# [required in production] Bearer token gating POST /v1/admin/media (the
# publish path — currently a 501 stub, wired up in the catalog-population sprint).
# Generate with: openssl rand -base64 32
CATALOG_ADMIN_TOKEN=
